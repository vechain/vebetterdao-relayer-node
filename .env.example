# Required: one of MNEMONIC or RELAYER_PRIVATE_KEY
MNEMONIC="word1 word2 word3 word4 word5 word6 word7 word8 word9 word10 word11 word12"
# RELAYER_PRIVATE_KEY=0xabc123...

# Network: mainnet | testnet-staging (default: testnet-staging)
RELAYER_NETWORK=testnet-staging

# Optional overrides
# NODE_URL=https://mainnet.vechain.org
# BATCH_SIZE=50
# DRY_RUN=0
# POLL_INTERVAL_MS=300000
# RUN_ONCE=0
